generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEDEWERKER
  TEAMLEIDER
  BEHEERDER
}

enum ModuleStatus {
  NIET_GESTART
  BEZIG
  AFGEROND
}

enum LearningGoalStatus {
  OPEN
  BEZIG
  AFGEROND
}

enum OnboardingContentType {
  TEXT
  VIDEO
  DOCUMENT
  MODULE_LINK
  CHECKLIST
}

enum ModuleSectionType {
  TEXT
  VIDEO
  QUIZ
  IMAGE
}

enum DocumentType {
  PROTOCOL
  WERKAFSPRAAK
  KERNBOODSCHAP
  FORMAT
  OVERIG
}

enum Visibility {
  PRIVATE
  TEAM
}

model User {
  id                 String                @id @default(cuid())
  email              String                @unique
  name               String
  role               Role
  title              String
  location           String
  bio                String
  avatarColor        String
  isOnboarding       Boolean               @default(false)
  buddyId            String?
  teamleaderId       String?
  buddy              User?                 @relation("BuddyRelation", fields: [buddyId], references: [id])
  buddyFor           User[]                @relation("BuddyRelation")
  teamleader         User?                 @relation("TeamleaderRelation", fields: [teamleaderId], references: [id])
  teamMembers        User[]                @relation("TeamleaderRelation")
  authoredModules    Module[]
  ownedDocuments     Document[]
  moduleProgress     ModuleProgress[]
  onboardingProgress OnboardingProgress[]
  learningGoals      LearningGoal[]
  developmentDocs    DevelopmentDocument[]
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  order     Int      @default(0)
  modules   Module[]
  documents Document[]
}

model Module {
  id               String           @id @default(cuid())
  title            String
  description      String
  thumbnailLabel   String?
  status           String
  isRequired       Boolean          @default(false)
  estimatedMinutes Int              @default(0)
  authorId         String
  categoryId       String
  author           User             @relation(fields: [authorId], references: [id])
  category         Category         @relation(fields: [categoryId], references: [id])
  sections         ModuleSection[]
  progress         ModuleProgress[]
}

model ModuleSection {
  id       String            @id @default(cuid())
  moduleId String
  order    Int
  title    String
  type     ModuleSectionType
  content  String
  quizData Json?
  module   Module            @relation(fields: [moduleId], references: [id])
}

model ModuleProgress {
  id          String       @id @default(cuid())
  userId      String
  moduleId    String
  status      ModuleStatus
  score       Int?
  startedAt   DateTime
  completedAt DateTime?
  user        User         @relation(fields: [userId], references: [id])
  module      Module       @relation(fields: [moduleId], references: [id])
}

model OnboardingPath {
  id          String           @id @default(cuid())
  name        String
  description String
  isActive    Boolean          @default(true)
  steps       OnboardingStep[]
}

model OnboardingStep {
  id          String                @id @default(cuid())
  pathId      String
  order       Int
  title       String
  description String
  contentType OnboardingContentType
  content     String
  isRequired  Boolean               @default(true)
  path        OnboardingPath        @relation(fields: [pathId], references: [id])
  progress    OnboardingProgress[]
}

model OnboardingProgress {
  id            String           @id @default(cuid())
  userId        String
  stepId        String
  completed     Boolean          @default(false)
  completedAt   DateTime?
  completedById String?
  notes         String?
  user          User             @relation(fields: [userId], references: [id])
  step          OnboardingStep   @relation(fields: [stepId], references: [id])
}

model Document {
  id          String       @id @default(cuid())
  title       String
  type        DocumentType
  summary     String
  content     Json
  version     String
  isPublished Boolean      @default(false)
  updatedAt   DateTime     @updatedAt
  ownerId     String
  categoryId  String
  owner       User         @relation(fields: [ownerId], references: [id])
  category    Category     @relation(fields: [categoryId], references: [id])
}

model LearningGoal {
  id          String             @id @default(cuid())
  userId      String
  title       String
  description String
  status      LearningGoalStatus
  targetDate  DateTime?
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id])
}

model DevelopmentDocument {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String
  category    String
  visibility  Visibility
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
}
